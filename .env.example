# Base de données
# Local : SQLite
DATABASE_URL="file:./dev.db"
# Production : PostgreSQL sur Render (remplacer par l'URL fournie par Render)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Anthropic - récupère ta clé sur https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# SMTP - exemple avec Gmail
# Pour Gmail : activer "Mots de passe d'application" dans les paramètres Google
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="ton@email.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"

# Expéditeur affiché dans les emails
SMTP_FROM_NAME="Ton Prénom"
SMTP_FROM_EMAIL="ton@email.com"
