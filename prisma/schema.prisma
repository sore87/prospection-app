generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Prospect {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  company     String
  domain      String
  position    String?
  linkedinUrl String?
  // Emails générés (3 variantes)
  email1      String?
  email2      String?
  email3      String?
  emailValid  String?  // email confirmé comme valide après envoi réussi
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaignProspects CampaignProspect[]
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("draft") // draft | active | paused | completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sequences         Sequence[]
  campaignProspects CampaignProspect[]
}

model Sequence {
  id         String   @id @default(cuid())
  campaignId String
  stepNumber Int      // 0 = J+0, 1 = J+3, 2 = J+7 ...
  delayDays  Int      @default(0)
  subject    String
  prompt     String   // prompt Claude pour générer le corps de l'email
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  emails   Email[]
}

model CampaignProspect {
  id           String   @id @default(cuid())
  campaignId   String
  prospectId   String
  currentStep  Int      @default(0)
  status       String   @default("pending") // pending | active | completed | unsubscribed
  enrolledAt   DateTime @default(now())

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prospect Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([campaignId, prospectId])
}

model Email {
  id           String    @id @default(cuid())
  sequenceId   String
  prospectId   String
  to           String    // adresse utilisée pour l'envoi
  subject      String
  body         String
  status       String    @default("pending") // pending | approved | rejected | sent | bounced | replied
  generatedAt  DateTime  @default(now())
  approvedAt   DateTime?
  sentAt       DateTime?
  bouncedAt    DateTime?
  repliedAt    DateTime?
  errorMessage String?

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
}
